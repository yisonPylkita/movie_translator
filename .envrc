# --- .envrc ---
if [ -f .python-version ]; then
  PY_VER="$(cat .python-version)"
else
  echo "ERROR: Python version not specified. Create .python-version file" >&2
  exit 1
fi
if ! command -v uv >/dev/null 2>&1; then
  echo "ERROR: uv not found. Install uv first." >&2
  exit 1
fi
uv python install --if-needed "$PY_VER"
if [ ! -d .venv ]; then
  uv venv --python "$PY_VER"
fi
PATH_add ".venv/bin"
export VIRTUAL_ENV="$PWD/.venv"
watch_file pyproject.toml
watch_file uv.lock
if [ -f uv.lock ]; then
  uv sync --frozen --group dev || uv sync --group dev
else
  uv sync --group dev
fi
dotenv_if_exists
